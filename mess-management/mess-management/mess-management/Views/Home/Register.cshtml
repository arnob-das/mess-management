@model Tuple<mess_management.Models.User, mess_management.Models.Manager>
@{
    ViewBag.Title = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" type="text/css" href="~/Content/Styles.css" />
</head>
<body>
    <div class="navbar">
        <a href="@Url.Action("Index", "Home")">Home</a>
        <a href="@Url.Action("Login", "Home")">Login</a>
    </div>
    <div class="register-container">
        <h2>Register</h2>
        @using (Html.BeginForm("RegisterUser", "Home", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="fullname">Full Name:</label>
                @Html.TextBoxFor(m => m.Item1.FullName, new { @id = "fullname", @class = "form-control", required = "required" })
                @Html.ValidationMessageFor(m => m.Item1.FullName)
            </div>
            <div class="form-group">
                <label for="email">Email:</label>
                @Html.TextBoxFor(m => m.Item1.Email, new { @id = "email", type = "email", @class = "form-control", required = "required" })
                @Html.ValidationMessageFor(m => m.Item1.Email)
            </div>
            <div class="form-group">
                <label for="password">Password:</label>
                @Html.PasswordFor(m => m.Item1.Password, new { @id = "password", @class = "form-control", required = "required" })
                @Html.ValidationMessageFor(m => m.Item1.Password)
            </div>
            <div class="form-group">
                <label for="nid">NID Number:</label>
                @Html.TextBoxFor(m => m.Item1.NID, new { @id = "nid", @class = "form-control", required = "required" })
                @Html.ValidationMessageFor(m => m.Item1.NID)
            </div>
            <div class="form-group">
                <label for="phone">Phone Number:</label>
                @Html.TextBoxFor(m => m.Item1.Phone, new { @id = "phone", @class = "form-control", required = "required" })
                @Html.ValidationMessageFor(m => m.Item1.Phone)
            </div>
            <div class="form-group">
                <label for="role">Register as:</label>
                @Html.DropDownList("role", new SelectList(new[]
                {
                    new SelectListItem { Text = "User", Value = "User" },
                    new SelectListItem { Text = "Manager", Value = "Manager" }
                }, "Value", "Text"), new { @id = "role", @class = "form-control", required = "required" })
            </div>

            <div id="managerFields" style="display:none;">
                <div class="form-group">
                    <label for="messId">Mess ID:</label>
                    @Html.TextBoxFor(m => m.Item2.MessId, new { @id = "messId", @class = "form-control" })
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Register</button>
        }
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var roleSelect = document.getElementById('role');
            var managerFields = document.getElementById('managerFields');

            roleSelect.addEventListener('change', function () {
                if (roleSelect.value === 'Manager') {
                    managerFields.style.display = 'block';
                } else {
                    managerFields.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>
