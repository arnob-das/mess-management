@{
    ViewBag.Title = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="login-page">
<head>
    <meta charset="UTF-8">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" type="text/css" href="~/Content/Login.css" />
    <style>
        body.login-page {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #f8f9fa;
            margin: 0;
        }

        .navbar {
            width: 100%;
            background-color: #343a40;
            padding: 10px 0;
            display: flex;
            justify-content: flex-end;
        }

            .navbar a {
                color: white;
                padding: 10px 20px;
                text-decoration: none;
                font-size: 16px;
            }

                .navbar a:hover {
                    background-color: #495057;
                }

        .login-container {
            background-color: white;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            max-width: 400px;
            width: 100%;
        }

            .login-container h2 {
                margin-bottom: 20px;
                color: #343a40;
            }

        .form-group {
            margin-bottom: 15px;
        }

            .form-group label {
                display: block;
                margin-bottom: 5px;
                color: #495057;
            }

            .form-group input {
                width: calc(100% - 22px);
                padding: 10px;
                border: 1px solid #ced4da;
                border-radius: 4px;
                font-size: 16px;
                box-sizing: border-box;
            }

        button {
            width: 100%;
            padding: 10px;
            background-color: #28a745;
            border: none;
            color: white;
            font-size: 16px;
            border-radius: 4px;
            cursor: pointer;
        }

            button:hover {
                background-color: #218838;
            }

        p {
            margin-top: 15px;
            color: #495057;
        }

            p a {
                color: #007bff;
                text-decoration: none;
            }

                p a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body class="login-page">
    <div class="navbar">
        <a href="@Url.Action("Index", "Home")">Home</a>
        <a href="@Url.Action("Login", "Home")">Login</a>
    </div>
    <div class="login-container">
        <h2>Login</h2>
        <form method="post" action="@Url.Action("Login", "Account")">
            <div class="form-group">
                <label for="username">Username:</label>
                <input type="text" id="username" name="username" required>
            </div>
            <div class="form-group">
                <label for="password">Password:</label>
                <input type="password" id="password" name="password" required>
            </div>
            <button type="submit">Login</button>
        </form>
        <p>Don't have an account? <a href="@Url.Action("Register", "Home")">Register here</a></p>
    </div>
</body>
</html>
