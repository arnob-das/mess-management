<?xml version="1.0" encoding="utf-8"?>
<Mapping Space="C-S" xmlns="http://schemas.microsoft.com/ado/2009/11/mapping/cs">
  <EntityContainerMapping StorageEntityContainer="MessModelStoreContainer" CdmEntityContainer="MessEntities1">
    <EntitySetMapping Name="Admins">
      <EntityTypeMapping TypeName="MessModel.Admin">
        <MappingFragment StoreEntitySet="Admin">
          <ScalarProperty Name="adminId" ColumnName="adminId" />
          <ScalarProperty Name="password" ColumnName="password" />
          <ScalarProperty Name="email" ColumnName="email" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="Costs">
      <EntityTypeMapping TypeName="MessModel.Cost">
        <MappingFragment StoreEntitySet="Cost">
          <ScalarProperty Name="costId" ColumnName="costId" />
