          <ScalarProperty Name="userId" ColumnName="userId" />
          <ScalarProperty Name="totalCost" ColumnName="totalCost" />
          <ScalarProperty Name="date" ColumnName="date" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="InventoryAssignments">
      <EntityTypeMapping TypeName="MessModel.InventoryAssignment">
        <MappingFragment StoreEntitySet="InventoryAssignment">
          <ScalarProperty Name="iaId" ColumnName="iaId" />
          <ScalarProperty Name="messId" ColumnName="messId" />
          <ScalarProperty Name="userId" ColumnName="userId" />
          <ScalarProperty Name="date" ColumnName="date" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="Managers">
      <EntityTypeMapping TypeName="MessModel.Manager">
        <MappingFragment StoreEntitySet="Manager">
          <ScalarProperty Name="managerId" ColumnName="managerId" />
          <ScalarProperty Name="email" ColumnName="email" />
          <ScalarProperty Name="password" ColumnName="password" />
          <ScalarProperty Name="messId" ColumnName="messId" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="MealCounts">
      <EntityTypeMapping TypeName="MessModel.MealCount">
        <MappingFragment StoreEntitySet="MealCount">
          <ScalarProperty Name="mealId" ColumnName="mealId" />
          <ScalarProperty Name="messId" ColumnName="messId" />
          <ScalarProperty Name="userId" ColumnName="userId" />
          <ScalarProperty Name="mealNum" ColumnName="mealNum" />
          <ScalarProperty Name="date" ColumnName="date" />
        </MappingFragment>
      </EntityTypeMapping>
    </EntitySetMapping>
    <EntitySetMapping Name="MealDeposits">
      <EntityTypeMapping TypeName="MessModel.MealDeposit">
        <MappingFragment StoreEntitySet="MealDeposit">
          <ScalarProperty Name="depositId" ColumnName="depositId" />
